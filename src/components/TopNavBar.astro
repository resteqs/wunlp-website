---
const { currentPath } = Astro.props;

const navItems = [
    { label: 'Home', href: '/' },
    { label: 'Team', href: '/team' },
    { label: 'Publications', href: '/publications' },
    { label: 'Teaching', href: '/teaching' },
    { label: 'News', href: '/news' },
];
---
<nav class="fixed top-0 w-full z-50 bg-surface/80 dark:bg-slate-900/80 backdrop-blur-md shadow-sm bg-opacity-90">
    <div class="flex justify-between items-center px-12 py-6 max-w-screen-2xl mx-auto">
        <a href="/" class="flex items-center gap-3">
            <img src="/logo.svg" alt="WüNLP Logo" class="h-16 w-auto -my-3" />
        </a>
        <div class="hidden md:flex space-x-8 items-center">
            {navItems.map(item => (
                <a 
                    href={item.href} 
                    class={`font-headline tracking-tight font-bold text-lg transition-colors px-3 py-2 rounded-md hover:bg-slate-100/50 dark:hover:bg-slate-800/50 ${
                        currentPath === item.href 
                        ? 'text-sky-700 dark:text-sky-400 border-b-2 border-sky-700 dark:border-sky-400 pb-1' 
                        : 'text-slate-600 dark:text-slate-400 hover:text-sky-600 dark:hover:text-sky-300'
                    }`}
                >
                    {item.label}
                </a>
            ))}
        </div>
        <div class="flex items-center space-x-4">
            <a href="/contact" class="hidden md:inline-flex bg-primary text-on-primary font-body font-semibold px-6 py-2.5 rounded-lg bg-gradient-to-br from-primary to-primary-container hover:shadow-md transition-shadow">
                Contact Us
            </a>
            <button class="md:hidden text-sky-700 dark:text-sky-400 p-2 hover:bg-slate-100/50 dark:hover:bg-slate-800/50 rounded-md transition-all scale-95">
                <span class="material-symbols-outlined">menu</span>
            </button>
        </div>
    </div>
</nav>
