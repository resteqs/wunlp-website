---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Imprint">
    <div class="px-6 md:px-12 max-w-screen-md mx-auto w-full">
        <header class="mb-12">
            <h1 class="text-[3rem] leading-tight font-headline text-on-surface mb-4">Imprint</h1>
            <p class="font-body text-on-surface-variant">Legal notice as required by German law (Impressum).</p>
        </header>

        <div class="prose prose-slate max-w-none font-body text-on-surface-variant space-y-8">
            <section class="bg-surface-container-low rounded-xl p-8">
                <h2 class="font-headline text-xl font-bold text-on-surface mb-4">Responsible for Content</h2>
                <p>
                    Chair of Natural Language Processing<br/>
                    University of Würzburg<br/>
                    Am Hubland<br/>
                    97074 Würzburg<br/>
                    Germany
                </p>
                <p class="mt-4">
                    <strong>Head of Chair:</strong> Prof. Dr. Goran Glavaš<br/>
                    <strong>Email:</strong> <a href="mailto:nlp@uni-wuerzburg.de" class="text-primary hover:underline">nlp@uni-wuerzburg.de</a>
                </p>
            </section>

            <section class="bg-surface-container-low rounded-xl p-8">
                <h2 class="font-headline text-xl font-bold text-on-surface mb-4">Institutional Affiliation</h2>
                <p>
                    The Chair of Natural Language Processing is part of the Center for Artificial Intelligence and Data Science (CAIDAS) at the Julius-Maximilians-Universität Würzburg.
                </p>
                <p class="mt-3">
                    <a href="https://www.uni-wuerzburg.de" target="_blank" rel="noopener" class="text-primary hover:underline">www.uni-wuerzburg.de</a>
                </p>
            </section>

            <section class="bg-surface-container-low rounded-xl p-8">
                <h2 class="font-headline text-xl font-bold text-on-surface mb-4">Disclaimer</h2>
                <p>
                    Despite careful control of content, we assume no liability for the content of external links. The operators of linked pages are solely responsible for their content.
                </p>
                <p class="mt-3">
                    All content on this website is protected by copyright. Reproduction, even partial, requires prior written permission.
                </p>
            </section>
        </div>
    </div>
</Layout>
