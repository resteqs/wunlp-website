---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allCourses = await getCollection('courses');
const sortedCourses = allCourses.sort((a, b) => a.data.order - b.data.order);

// Group by semester
const bySemester: Record<string, typeof allCourses> = {};
for (const course of sortedCourses) {
    if (!bySemester[course.data.semester]) bySemester[course.data.semester] = [];
    bySemester[course.data.semester].push(course);
}
const semesters = Object.keys(bySemester);

const typeIcon: Record<string, string> = {
    Lecture: 'school',
    Seminar: 'groups',
    Practical: 'terminal',
};
---

<Layout title="Teaching">
    <div class="px-6 md:px-12 max-w-screen-xl mx-auto w-full">
        <header class="mb-16">
            <h1 class="text-[3.5rem] leading-tight font-headline text-on-surface mb-4">Teaching</h1>
            <p class="text-xl font-body text-on-surface-variant max-w-3xl">
                Courses offered by the WüNLP Chair at the University of Würzburg. To add or update a course, edit the files in <code class="font-mono text-sm bg-surface-container px-2 py-0.5 rounded">src/content/courses/</code>.
            </p>
        </header>

        {semesters.map(semester => (
            <section class="mb-16">
                <h2 class="font-headline text-2xl font-bold text-on-surface mb-8 border-l-4 border-primary pl-4">{semester}</h2>
                <div class="space-y-4">
                    {bySemester[semester].map(course => (
                        <div class="bg-surface-container-low rounded-xl p-6 hover:bg-surface-container-high transition-colors group">
                            <div class="flex flex-col md:flex-row gap-4 items-start">
                                <!-- Type badge & icon -->
                                <div class="flex items-center gap-3 w-full md:w-56 shrink-0">
                                    <div class="w-10 h-10 bg-surface-container-lowest rounded-lg flex items-center justify-center shadow-sm">
                                        <span class="material-symbols-outlined text-xl text-primary">
                                            {typeIcon[course.data.type] ?? 'book'}
                                        </span>
                                    </div>
                                    <div>
                                        <span class="block font-label text-xs uppercase tracking-wider text-outline">{course.data.type}</span>
                                        {course.data.ects && (
                                            <span class="block font-label text-xs text-outline">{course.data.ects} ECTS</span>
                                        )}
                                    </div>
                                </div>

                                <!-- Details -->
                                <div class="flex-grow">
                                    <h3 class="font-headline text-xl font-semibold text-on-surface group-hover:text-primary transition-colors mb-1">
                                        {course.url ? (
                                            <a href={course.data.url}>{course.data.title}</a>
                                        ) : course.data.title}
                                    </h3>
                                    {course.data.lecturers && (
                                        <p class="font-body text-sm text-on-surface-variant mb-2">{course.data.lecturers}</p>
                                    )}
                                    <p class="font-body text-sm text-on-surface-variant">{course.body?.trim()}</p>
                                </div>

                                <!-- Language -->
                                <div class="shrink-0 flex items-center gap-1 text-outline font-label text-sm">
                                    <span class="material-symbols-outlined text-[16px]">language</span>
                                    {course.data.language}
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </section>
        ))}

        {semesters.length === 0 && (
            <div class="text-center py-24 text-on-surface-variant font-body">
                No courses yet. Add a file to <code class="font-mono text-sm bg-surface-container px-2 py-0.5 rounded">src/content/courses/</code> to get started.
            </div>
        )}
    </div>
</Layout>
