---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allTeam = await getCollection('team');
const sort = (a: typeof allTeam[number], b: typeof allTeam[number]) => a.data.order - b.data.order;

const pis = allTeam.filter(m => m.data.group === 'pi' || m.data.group === 'postdoc').sort(sort);
const researchers = allTeam.filter(m => m.data.group === 'phd' || m.data.group === 'master' || m.data.group === 'student').sort(sort);

const groupLabel: Record<string, string> = {
    pi: 'Head of Chair',
    postdoc: 'Postdoctoral Researcher',
    phd: 'PhD Student',
    master: "Master's Student",
    student: 'Student Researcher',
};

const groupBadgeClass: Record<string, string> = {
    pi: 'bg-primary-container text-on-primary-container',
    postdoc: 'bg-secondary-container text-on-secondary-container',
    phd: 'bg-secondary-container text-on-secondary-container',
    master: 'bg-tertiary-container text-on-tertiary-fixed',
    student: 'bg-surface-container-high text-on-surface-variant',
};
---

<Layout title="Team">
    <div class="px-6 md:px-12 max-w-screen-2xl mx-auto w-full">
        <!-- Header -->
        <header class="mb-16 md:mb-24 max-w-4xl">
            <span class="font-label text-sm font-semibold tracking-widest uppercase text-tertiary-container mb-4 block">The People Behind the Models</span>
            <h1 class="font-headline text-5xl md:text-7xl font-bold text-on-surface leading-tight mb-6">Our Research Team</h1>
            <p class="font-body text-lg md:text-xl text-on-surface-variant leading-relaxed max-w-2xl">
                A multidisciplinary group of researchers, engineers, and students dedicated to advancing the frontier of Natural Language Processing and understanding human communication through computational methods.
            </p>
        </header>

        <!-- Principal Investigators & Postdocs -->
        <section class="mb-20">
            <h2 class="font-headline text-3xl font-bold text-on-surface mb-10 border-l-4 border-primary pl-4">Principal Investigators</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {pis.map(member => (
                    <div class="group relative bg-surface-container-low rounded-xl overflow-hidden transition-all duration-300 hover:bg-surface-container-high">
                        {member.data.photo && (
                            <div class="relative h-[300px]">
                                <img
                                    src={member.data.photo}
                                    alt={member.data.name}
                                    class="object-cover w-full h-full grayscale group-hover:grayscale-0 transition-all duration-500"
                                />
                                <div class="absolute bottom-0 left-0 w-full p-6 bg-gradient-to-t from-black/80 to-transparent">
                                    <div class="bg-surface-container-lowest/90 glass-panel p-4 rounded-lg inline-block transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                                        <h3 class="font-headline text-2xl font-bold text-on-surface mb-1">{member.data.name}</h3>
                                        <p class="font-label text-sm text-primary font-medium">{member.data.role}</p>
                                    </div>
                                </div>
                            </div>
                        )}
                        <div class="p-6 pt-8">
                            {!member.data.photo && (
                                <div class="mb-4">
                                    <h3 class="font-headline text-2xl font-bold text-on-surface mb-1">{member.data.name}</h3>
                                    <p class="font-label text-sm text-primary font-medium">{member.data.role}</p>
                                </div>
                            )}
                            {member.data.researchFocus && (
                                <p class="font-body text-on-surface-variant mb-6 text-sm leading-relaxed">{member.data.researchFocus}</p>
                            )}
                            <div class="flex items-center space-x-4">
                                {member.data.profileUrl && (
                                    <a href={member.data.profileUrl} class="text-tertiary hover:text-primary transition-colors flex items-center space-x-1 text-sm font-medium">
                                        <span class="material-symbols-outlined text-[18px]">person</span>
                                        <span>Profile</span>
                                    </a>
                                )}
                                {member.data.publicationsUrl && (
                                    <a href={member.data.publicationsUrl} class="text-tertiary hover:text-primary transition-colors flex items-center space-x-1 text-sm font-medium">
                                        <span class="material-symbols-outlined text-[18px]">article</span>
                                        <span>Publications</span>
                                    </a>
                                )}
                                {member.data.websiteUrl && (
                                    <a href={member.data.websiteUrl} class="text-tertiary hover:text-primary transition-colors flex items-center space-x-1 text-sm font-medium">
                                        <span class="material-symbols-outlined text-[18px]">open_in_new</span>
                                        <span>Website</span>
                                    </a>
                                )}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- PhD & Student Researchers -->
        <section class="mb-20">
            <h2 class="font-headline text-3xl font-bold text-on-surface mb-10 border-l-4 border-secondary pl-4">PhD Researchers</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {researchers.map(member => (
                    <div class="bg-surface-container-lowest rounded-xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_12px_24px_-8px_rgba(9,29,46,0.08)]">
                        <div class="flex items-start justify-between mb-4">
                            {member.data.photo ? (
                                <img
                                    src={member.data.photo}
                                    alt={member.data.name}
                                    class="w-16 h-16 rounded-full object-cover border-2 border-surface-container-low"
                                />
                            ) : (
                                <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center border-2 border-surface-container-low">
                                    <span class="material-symbols-outlined text-3xl text-outline">person</span>
                                </div>
                            )}
                            <span class={`font-label text-xs font-bold px-2 py-1 rounded-sm uppercase tracking-wider ${groupBadgeClass[member.data.group]}`}>
                                {groupLabel[member.data.group]}
                            </span>
                        </div>
                        <h3 class="font-headline text-xl font-bold text-on-surface mb-1">{member.data.name}</h3>
                        {member.data.researchFocus && (
                            <p class="font-body text-sm text-tertiary mb-4">{member.data.researchFocus}</p>
                        )}
                        {member.data.profileUrl && (
                            <a href={member.data.profileUrl} class="inline-flex items-center text-sm font-medium text-primary hover:text-primary-container transition-colors group">
                                View Profile
                                <span class="material-symbols-outlined text-[16px] ml-1 group-hover:translate-x-1 transition-transform">arrow_forward</span>
                            </a>
                        )}
                    </div>
                ))}
            </div>
        <!-- Join Us CTA -->
        <section class="mb-20">
            <div class="bg-inverse-surface text-inverse-on-surface rounded-xl p-10 md:p-16 flex flex-col md:flex-row gap-10 items-center justify-between">
                <div class="max-w-2xl">
                    <h2 class="font-headline text-3xl md:text-4xl font-bold mb-4 text-inverse-primary">
                        Join Our Team
                    </h2>
                    <p class="font-body text-lg opacity-90 leading-relaxed">
                        We are always looking for motivated <strong>PhD students</strong> and <strong>student researchers</strong> with a passion for Natural Language Processing, machine learning, and multilingual AI. 
                        Whether you are finishing your Bachelor's, currently in a Master's programme, or holding a Master's degree — we'd love to hear from you.
                    </p>
                    <p class="font-body mt-3 opacity-75 text-sm">
                        Please send a short statement of interest and your CV to our general contact address.
                    </p>
                </div>
                <div class="flex flex-col gap-4 shrink-0">
                    <a href="/contact" class="bg-primary text-on-primary font-body font-semibold py-3 px-8 rounded-lg hover:bg-primary-container transition-colors shadow-sm text-center whitespace-nowrap">
                        Contact Us
                    </a>
                    <a href="/publications" class="border border-inverse-on-surface/30 text-inverse-on-surface font-body font-semibold py-3 px-8 rounded-lg hover:bg-surface-container-low/10 transition-colors text-center whitespace-nowrap opacity-80">
                        View Our Research
                    </a>
                </div>
            </div>
        </section>
    </div>
</Layout>

