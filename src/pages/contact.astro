---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const settingsEntries = await getCollection('settings');
const site = settingsEntries[0].data;
---

<Layout title="Contact">
    <div class="px-6 md:px-12 max-w-screen-xl mx-auto w-full">
        <header class="mb-16 max-w-2xl">
            <h1 class="text-[3.5rem] leading-tight font-headline text-on-surface mb-4">Contact Us</h1>
            <p class="text-xl font-body text-on-surface-variant">
                Get in touch with the WüNLP Chair at the University of Würzburg. We welcome inquiries from prospective students, collaborators, and the press.
            </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20">
            <!-- General Contact -->
            <div class="bg-surface-container-low rounded-xl p-8">
                <div class="w-12 h-12 bg-surface-container-lowest rounded-lg flex items-center justify-center mb-6 shadow-sm">
                    <span class="material-symbols-outlined text-2xl text-primary">mail</span>
                </div>
                <h2 class="font-headline text-2xl font-bold mb-3">General Inquiries</h2>
                <p class="font-body text-on-surface-variant mb-4">For general questions about the chair, our research, or collaboration opportunities:</p>
                {site.contactEmail && (
                    <a href={`mailto:${site.contactEmail}`} class="font-body text-primary font-semibold hover:underline underline-offset-4">
                        {site.contactEmail}
                    </a>
                )}
            </div>

            <!-- Address -->
            <div class="bg-surface-container-low rounded-xl p-8">
                <div class="w-12 h-12 bg-surface-container-lowest rounded-lg flex items-center justify-center mb-6 shadow-sm">
                    <span class="material-symbols-outlined text-2xl text-primary">location_on</span>
                </div>
                <h2 class="font-headline text-2xl font-bold mb-3">Address</h2>
                <address class="font-body text-on-surface-variant not-italic leading-relaxed">
                    Chair of Natural Language Processing<br/>
                    University of Würzburg<br/>
                    Am Hubland<br/>
                    97074 Würzburg, Germany
                </address>
            </div>

            <!-- Prospective Students -->
            <div class="bg-surface-container-low rounded-xl p-8">
                <div class="w-12 h-12 bg-surface-container-lowest rounded-lg flex items-center justify-center mb-6 shadow-sm">
                    <span class="material-symbols-outlined text-2xl text-primary">school</span>
                </div>
                <h2 class="font-headline text-2xl font-bold mb-3">Prospective Students</h2>
                <p class="font-body text-on-surface-variant mb-4">
                    Interested in joining us as a PhD student or student researcher? We are always looking for motivated candidates. Please send your CV and a brief statement of interest to the general contact email above.
                </p>
                <a href={`${import.meta.env.BASE_URL}team`} class="font-body text-primary font-semibold hover:underline underline-offset-4 flex items-center gap-1">
                    Meet our team <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
            </div>

            <!-- University -->
            <div class="bg-surface-container-low rounded-xl p-8">
                <div class="w-12 h-12 bg-surface-container-lowest rounded-lg flex items-center justify-center mb-6 shadow-sm">
                    <span class="material-symbols-outlined text-2xl text-primary">open_in_new</span>
                </div>
                <h2 class="font-headline text-2xl font-bold mb-3">University of Würzburg</h2>
                <p class="font-body text-on-surface-variant mb-4">Our chair is part of the Center for Artificial Intelligence and Data Science (CAIDAS) at the University of Würzburg.</p>
                <a href="https://www.caidas.uni-wuerzburg.de/nlp/" target="_blank" rel="noopener" class="font-body text-primary font-semibold hover:underline underline-offset-4 flex items-center gap-1">
                    Visit official page <span class="material-symbols-outlined text-sm">open_in_new</span>
                </a>
            </div>
        </div>
    </div>
</Layout>
