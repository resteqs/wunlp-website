---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const [settingsEntries, newsEntries] = await Promise.all([
    getCollection('settings'),
    getCollection('news'),
]);

const site = settingsEntries[0].data;
const latestNews = newsEntries
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 3);

// Format date as "OCT 12, 2024"
function fmtDate(d: Date) {
    return d.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' }).toUpperCase();
}
---

<Layout title="Home">
    <!-- Hero Section -->
    <section class="relative px-6 md:px-12 py-20 max-w-screen-2xl mx-auto">
        <div class="absolute inset-0 z-0 overflow-hidden rounded-xl">
            {site.heroImageUrl && (
                <img
                    src={site.heroImageUrl}
                    alt="Abstract digital network visualization"
                    class="w-full h-full object-cover opacity-20"
                />
            )}
            <div class="absolute inset-0 bg-gradient-to-r from-surface via-surface/90 to-transparent"></div>
        </div>

        <div class="relative z-10 max-w-3xl">
            <p class="text-secondary font-label uppercase tracking-widest text-sm mb-4 font-semibold">{site.heroTagline}</p>
            <h1 class="font-headline text-5xl md:text-7xl font-bold leading-tight mb-8 text-on-surface">
                {site.heroHeadlineLine1} <br/>
                <span class="text-primary">{site.heroHeadlineLine2}</span>
            </h1>
            <p class="font-body text-xl text-on-surface-variant leading-relaxed mb-10 max-w-2xl">
                {site.heroBody}
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
                <a href="/research" class="bg-primary text-on-primary px-8 py-4 rounded-lg font-label font-semibold shadow-md hover:bg-primary-container transition-colors flex items-center justify-center gap-2">
                    Explore Our Research
                    <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                </a>
                <a href="/publications" class="px-8 py-4 rounded-lg font-label font-semibold text-primary border border-outline-variant hover:bg-surface-container-low transition-colors flex items-center justify-center text-center">
                    Read Latest Papers
                </a>
            </div>
        </div>
    </section>

    <!-- Bento Grid: Featured Research & News -->
    <section class="px-6 md:px-12 py-16 max-w-screen-2xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6">

            <!-- Main Feature Card -->
            <div class="md:col-span-8 bg-surface-container-low rounded-xl p-8 md:p-12 relative overflow-hidden flex flex-col justify-between min-h-[400px]">
                <div class="absolute top-0 right-0 w-64 h-64 bg-primary-container/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/4"></div>
                <div class="relative z-10">
                    <span class="inline-block bg-primary text-on-primary text-xs font-label font-bold px-3 py-1 rounded-full mb-6 uppercase tracking-wider">Core Research</span>
                    <h2 class="font-headline text-3xl md:text-4xl font-bold mb-4">{site.featuredResearchTitle}</h2>
                    <p class="font-body text-on-surface-variant max-w-xl text-lg mb-8">{site.featuredResearchBody}</p>
                </div>
                <div class="relative z-10 flex items-end justify-end">
                    <a href="/research" class="text-primary font-label font-medium hover:underline flex items-center gap-1">
                        View Research <span class="material-symbols-outlined text-sm">chevron_right</span>
                    </a>
                </div>
            </div>

            <!-- Latest News Feed -->
            <div class="md:col-span-4 bg-surface-container-lowest rounded-xl p-8 ambient-shadow flex flex-col">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="font-headline text-xl font-bold">Latest Updates</h3>
                    <span class="material-symbols-outlined text-outline">feed</span>
                </div>
                <div class="space-y-6 flex-grow">
                    {latestNews.map(item => (
                        <article class="group cursor-pointer">
                            <p class="text-secondary font-label text-xs font-bold mb-1">{fmtDate(item.data.date)}</p>
                            <h4 class="font-body font-semibold text-on-surface group-hover:text-primary transition-colors">{item.data.title}</h4>
                        </article>
                    ))}
                </div>
                <a href="/publications" class="mt-6 block w-full py-3 text-center text-sm font-label font-medium text-primary border-t border-surface-container-high hover:bg-surface-container-low transition-colors">
                    View All News
                </a>
            </div>

            <!-- Research Area Teasers -->
            <div class="md:col-span-6 bg-surface-container-low rounded-xl p-8 hover:bg-surface-container-high transition-colors cursor-pointer group">
                <span class="material-symbols-outlined text-primary mb-4 text-3xl">psychology</span>
                <h3 class="font-headline text-2xl font-bold mb-3 group-hover:text-primary transition-colors">Cognitive Modeling</h3>
                <p class="font-body text-on-surface-variant">Bridging human cognitive processes with neural network attention mechanisms to improve interpretability.</p>
            </div>
            <div class="md:col-span-6 bg-surface-container-low rounded-xl p-8 hover:bg-surface-container-high transition-colors cursor-pointer group">
                <span class="material-symbols-outlined text-primary mb-4 text-3xl">gavel</span>
                <h3 class="font-headline text-2xl font-bold mb-3 group-hover:text-primary transition-colors">Algorithmic Fairness</h3>
                <p class="font-body text-on-surface-variant">Detecting and mitigating inherent biases in large-scale pre-trained models used in critical decision systems.</p>
            </div>

        </div>
    </section>
</Layout>
