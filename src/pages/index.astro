---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const [settingsEntries, newsEntries] = await Promise.all([
    getCollection('settings'),
    getCollection('news'),
]);

const site = settingsEntries[0].data;
const latestNews = newsEntries
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 4);

function fmtDate(d: Date) {
    return d.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' }).toUpperCase();
}
---

<Layout title="Home">
    <!-- Hero Section: full-width text over background image -->
    <section class="relative px-6 md:px-12 py-24 max-w-screen-2xl mx-auto">

        <!-- Background image + gradient -->
        <div class="absolute inset-0 z-0 overflow-hidden rounded-xl">
            {site.heroImageUrl && (
                <img
                    src={site.heroImageUrl}
                    alt="Abstract digital network visualization"
                    class="w-full h-full object-cover opacity-20"
                />
            )}
            <!-- Gradient covers full surface so wide text stays readable -->
            <div class="absolute inset-0 bg-gradient-to-b from-surface/95 via-surface/90 to-surface/80"></div>
        </div>

        <!-- Hero text: wide, full column -->
        <div class="relative z-10 max-w-4xl">
            <p class="text-secondary font-label uppercase tracking-widest text-sm mb-4 font-semibold">{site.heroTagline}</p>
            <h1 class="font-headline text-5xl md:text-7xl font-bold leading-tight mb-8 text-on-surface">
                {site.heroHeadlineLine1} <br/>
                <span class="text-primary">{site.heroHeadlineLine2}</span>
            </h1>
            <!-- Body text is now max-w-4xl (matches the container) — readable because gradient is a soft top-down veil -->
            <p class="font-body text-xl text-on-surface-variant leading-relaxed mb-10">
                {site.heroBody}
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
                <a href="/team" class="bg-primary text-on-primary px-8 py-4 rounded-lg font-label font-semibold shadow-md hover:bg-primary-container transition-colors flex items-center justify-center gap-2">
                    Meet Our Team
                    <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                </a>
                <a href="/publications" class="px-8 py-4 rounded-lg font-label font-semibold text-primary border border-outline-variant hover:bg-surface-container-low transition-colors flex items-center justify-center text-center">
                    Read Latest Papers
                </a>
            </div>
        </div>
    </section>

    <!-- Latest News — structure mirrored from Hero to ensure EXACT width match -->
    <section class="relative px-6 md:px-12 py-10 md:py-12 mb-20 max-w-screen-2xl mx-auto">
        <!-- Background strictly matching the hero's absolute bounds -->
        <div class="absolute inset-0 z-0 bg-surface-container-lowest rounded-xl ambient-shadow"></div>
        
        <div class="relative z-10">
            <div class="flex items-center justify-between mb-8">
                <h3 class="font-headline text-xl font-bold">Latest Updates</h3>
                <span class="material-symbols-outlined text-outline">feed</span>
            </div>
            <div class="space-y-6">
                {latestNews.map(item => (
                    <article class="group cursor-pointer border-l-2 border-surface-container-high pl-4 hover:border-primary transition-colors">
                        <p class="text-secondary font-label text-xs font-bold mb-1">{fmtDate(item.data.date)}</p>
                        <h4 class="font-body font-semibold text-on-surface group-hover:text-primary transition-colors mb-2">{item.data.title}</h4>
                        {item.body?.trim() && (
                            <p class="font-body text-sm text-on-surface-variant leading-relaxed">
                                {item.body.trim().slice(0, 1024)}{item.body.trim().length > 1024 ? '…' : ''}
                            </p>
                        )}
                    </article>
                ))}
            </div>
            <div class="mt-8 pt-6 border-t border-surface-container-high text-right">
                <a href="/news" class="text-sm font-label font-medium text-primary hover:underline underline-offset-4 flex items-center gap-1 justify-end">
                    View All News <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                </a>
            </div>
        </div>
    </section>
</Layout>
